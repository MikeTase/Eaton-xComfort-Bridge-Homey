{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build",
			"type": "npm",
			"script": "build",
			"group": "build",
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "Homey: Run",
			"type": "shell",
			"command": "npx homey app run",
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"clear": true
			}
		},
		{
			"label": "Update app.json",
			"type": "shell",
			"command": "node ./update_app_json.js"
		},
		{
			"label": "Build test",
			"type": "shell",
			"command": "npm run build"
		},
		{
			"label": "Build check",
			"type": "shell",
			"command": "npm run build"
		},
		{
			"label": "Build Verify",
			"type": "shell",
			"command": "npm run build"
		},
		{
			"label": "Bump version",
			"type": "shell",
			"command": "node -e \"const fs = require('fs'); const file = './app.json'; const data = JSON.parse(fs.readFileSync(file, 'utf8')); data.version = '1.4.12'; fs.writeFileSync(file, JSON.stringify(data, null, 2));\""
		},
		{
			"label": "Publish App",
			"type": "shell",
			"command": "homey app publish"
		},
		{
			"label": "Commit and Publish App",
			"type": "shell",
			"command": "git add . && git commit -m \"Add flow capabilities for thermostat presets\" && homey app publish"
		}
	]
}