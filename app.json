{
  "id": "eaton.xcomfort.bridge",
  "name": {
    "en": "Eaton xComfort"
  },
  "description": {
    "en": "Seamless Eaton xComfort control for lights, shades, and heating."
  },
  "version": "1.4.54",
  "category": [
    "lights",
    "climate"
  ],
  "tags": {
    "en": [
      "eaton",
      "xcomfort",
      "smart home",
      "lighting",
      "heating",
      "shading",
      "blinds",
      "thermostat"
    ]
  },
  "brandColor": "#005EB8",
  "support": "https://github.com/MikeTase/Eaton-xComfort-Bridge-Homey/issues",
  "bugs": {
    "url": "https://github.com/MikeTase/Eaton-xComfort-Bridge-Homey/issues"
  },
  "source": "https://github.com/MikeTase/Eaton-xComfort-Bridge-Homey",
  "homeyCommunityTopicId": 839,
  "images": {
    "large": "assets/images/large.png",
    "small": "assets/images/small.png"
  },
  "author": {
    "name": "Mike Taselaar"
  },
  "compatibility": ">=12.0.1",
  "sdk": 3,
  "permissions": [],
  "flow": {
    "triggers": [
      {
        "id": "wall_switch_pressed",
        "title": {
          "en": "Wall switch pressed (any)"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=wall_switch"
          }
        ],
        "tokens": [
          {
            "name": "event",
            "type": "string",
            "title": {
              "en": "Event"
            }
          },
          {
            "name": "action",
            "type": "string",
            "title": {
              "en": "Action"
            }
          },
          {
            "name": "button",
            "type": "number",
            "title": {
              "en": "Button"
            }
          },
          {
            "name": "component_id",
            "type": "string",
            "title": {
              "en": "Component ID"
            }
          },
          {
            "name": "component_model",
            "type": "string",
            "title": {
              "en": "Component Model"
            }
          }
        ]
      },
      {
        "id": "wall_switch_up",
        "title": {
          "en": "Wall switch pressed (up/on)"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=wall_switch"
          }
        ]
      },
      {
        "id": "wall_switch_down",
        "title": {
          "en": "Wall switch pressed (down/off)"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=wall_switch"
          }
        ]
      },
      {
        "id": "thermostat_button_on",
        "title": {
          "en": "Thermostat button pressed (right/on)"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=thermostat"
          }
        ]
      },
      {
        "id": "thermostat_button_off",
        "title": {
          "en": "Thermostat button pressed (left/off)"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=thermostat"
          }
        ]
      },
      {
        "id": "xcomfort_preset_changed",
        "title": {
          "en": "Heating preset changed"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=thermostat"
          }
        ],
        "tokens": [
          {
            "name": "preset",
            "type": "string",
            "title": {
              "en": "Preset"
            }
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "xcomfort_preset_is",
        "title": {
          "en": "Heating preset is"
        },
        "titleFormatted": {
          "en": "Heating preset is [[preset]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=thermostat"
          },
          {
            "name": "preset",
            "type": "dropdown",
            "values": [
              {
                "id": "frost",
                "label": {
                  "en": "Frost"
                }
              },
              {
                "id": "eco",
                "label": {
                  "en": "Economy"
                }
              },
              {
                "id": "comfort",
                "label": {
                  "en": "Comfort"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "water_valve_is",
        "title": {
          "en": "Water valve is"
        },
        "titleFormatted": {
          "en": "Water valve !{{is|is not}} open"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=water_sensor"
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "set_xcomfort_preset",
        "title": {
          "en": "Set Heating preset"
        },
        "titleFormatted": {
          "en": "Set heating preset to [[preset]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=thermostat"
          },
          {
            "name": "preset",
            "type": "dropdown",
            "values": [
              {
                "id": "frost",
                "label": {
                  "en": "Frost"
                }
              },
              {
                "id": "eco",
                "label": {
                  "en": "Economy"
                }
              },
              {
                "id": "comfort",
                "label": {
                  "en": "Comfort"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "set_water_valve",
        "title": {
          "en": "Set water valve"
        },
        "titleFormatted": {
          "en": "Set water valve to [[state]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=water_sensor"
          },
          {
            "name": "state",
            "type": "dropdown",
            "values": [
              {
                "id": "closed",
                "label": {
                  "en": "Closed"
                }
              },
              {
                "id": "open",
                "label": {
                  "en": "Open"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "activate_xcomfort_scene",
        "title": {
          "en": "Activate xComfort scene"
        },
        "titleFormatted": {
          "en": "Activate [[device]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=scene"
          }
        ]
      },
      {
        "id": "switch_xcomfort_room_lights",
        "title": {
          "en": "Switch xComfort room lights"
        },
        "titleFormatted": {
          "en": "Switch room lights [[state]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=room_status"
          },
          {
            "name": "state",
            "type": "dropdown",
            "values": [
              {
                "id": "on",
                "label": {
                  "en": "On"
                }
              },
              {
                "id": "off",
                "label": {
                  "en": "Off"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "reset_energy_meter",
        "title": {
          "en": "Reset energy meter"
        },
        "titleFormatted": {
          "en": "Reset energy meter of [[device]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "capabilities=meter_power"
          }
        ]
      },
      {
        "id": "activate_scene_by_name",
        "title": {
          "en": "Activate scene by name"
        },
        "titleFormatted": {
          "en": "Activate scene [[scene]]"
        },
        "args": [
          {
            "name": "scene",
            "type": "autocomplete",
            "placeholder": {
              "en": "Scene"
            }
          }
        ]
      },
      {
        "id": "switch_room_lights_by_name",
        "title": {
          "en": "Switch room lights by name"
        },
        "titleFormatted": {
          "en": "Switch room [[room]] lights [[state]]"
        },
        "args": [
          {
            "name": "room",
            "type": "autocomplete",
            "placeholder": {
              "en": "Room"
            }
          },
          {
            "name": "state",
            "type": "dropdown",
            "values": [
              {
                "id": "on",
                "label": {
                  "en": "On"
                }
              },
              {
                "id": "off",
                "label": {
                  "en": "Off"
                }
              }
            ]
          }
        ]
      }
    ]
  },
